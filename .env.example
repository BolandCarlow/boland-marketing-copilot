NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth redirects always return to https://boland-marketing-copilot.vercel.app/auth/callback

# Generate with: openssl rand -base64 32
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=

# Meta Ads OAuth. No credentials are committed to source control.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://boland-marketing-copilot.vercel.app/api/integrations/meta-ads/callback
META_GRAPH_API_VERSION=v23.0
META_OAUTH_SCOPES=ads_read,read_insights
# Generate with: openssl rand -base64 32
META_CREDENTIALS_ENCRYPTION_KEY=
NEXT_PUBLIC_APP_URL=https://boland-marketing-copilot.vercel.app

# Generate with: openssl rand -hex 32
MARKETING_SYNC_API_SECRET=

# Vercel sends this value as a Bearer token to the daily Meta sync cron.
# Generate with: openssl rand -hex 32
CRON_SECRET=
