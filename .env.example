NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth redirects always return to https://boland-marketing-copilot.vercel.app/auth/callback

# Generate with: openssl rand -base64 32
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=

# Generate with: openssl rand -hex 32
MARKETING_SYNC_API_SECRET=

# Google Analytics 4 OAuth. The callback URL must be registered in Google Cloud.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GA_TOKEN_ENCRYPTION_KEY=
GA4_CRON_SECRET=
GA4_PROPERTY_ID=259586098
GOOGLE_ANALYTICS_REDIRECT_URI=https://boland-marketing-copilot.vercel.app/api/integrations/google-analytics/callback
